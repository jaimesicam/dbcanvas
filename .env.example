# Host interface the application is reachable on. Default: 127.0.0.1 (private —
# this machine only).
# - 127.0.0.1 (or another IPv4, e.g. 192.168.1.10) restricts access to that
#   interface. In Docker this binds the published port to that host interface;
#   the container itself always listens on all interfaces internally.
# - 0.0.0.0 exposes the app on all interfaces (e.g. your LAN).
APP_HOST=127.0.0.1

# Port the application listens on (host + container). Default: 8080
APP_PORT=8080

# Target platform for the Docker image build. Default: linux/amd64
DOCKER_PLATFORM=linux/amd64

# How long (in minutes) a provisioner waits for a dependency — an associated
# cluster, node, or shared service — to become ready before failing the deploy
# (e.g. "associated PXC cluster ... did not become ready within ..."). Raise
# this when deploying large stacks with many containers, which routinely take
# longer than a few minutes to come up. Default: 60
DEPLOYMENT_TIMEOUT=60

# Domain used to configure deployed stacks (e.g. the Intranet node: LDAP base DN,
# mail, DNS, CA). Default: example.net
DOMAIN=example.net

# Database users created on deployed Percona XtraDB Cluster nodes: an
# application user, a replication user, a monitoring user (used by ProxySQL's
# health checks as MONITOR_USERNAME), and a cluster admin user (used by
# ProxySQL's proxysql-admin as CLUSTER_USERNAME). Their passwords are taken
# from here.
APP_PASSWORD=app_password
REPL_PASSWORD=repl_password
MONITOR_PASSWORD=monitor_password
CLUSTER_PASSWORD=cluster_password

# Credentials for deployed database and ProxySQL nodes are taken exclusively from
# this file — they can no longer be set per-node on the canvas, and a redeploy
# re-reads these values. Variables named after a specific engine (MYSQL_*,
# POSTGRES_*, VALKEY_*, MONGODB_*, PROXYSQL_*) apply only to that engine family;
# the rest (APP/REPL/MONITOR/CLUSTER/PMM) are shared where relevant.

# Root (superuser) password for every MySQL-family database node — Percona
# XtraDB Cluster, MySQL replication, InnoDB / Group Replication, and standalone
# Percona Server (root@localhost).
MYSQL_ROOT_PASSWORD=root_password

# Password for the dedicated remote superuser account admin@'%' created on every
# MySQL-family node (PXC, MySQL replication, InnoDB / Group Replication, standalone
# Percona Server). root@localhost cannot connect over the network, so this account
# is the network-reachable full-privilege admin.
MYSQL_ADMIN_PASSWORD=admin_password

# Superuser (postgres) password for every PostgreSQL node.
POSTGRES_PASSWORD=postgres_password

# Default-user password (requirepass / masterauth) for every Valkey node —
# standalone and Valkey Cluster.
VALKEY_PASSWORD=valkey_password

# Admin-interface (port 6032) password for the ProxySQL 'admin' user on every
# ProxySQL node — standalone and ProxySQL cluster members.
PROXYSQL_ADMIN_PASSWORD=admin_password

# Admin-user password for every MongoDB (Percona Server for MongoDB) node —
# standalone, replica set, and sharded cluster.
MONGODB_ADMIN_PASSWORD=admin_password

# Password for the dedicated "pmm" monitoring account that PMM uses to scrape
# metrics from each monitored database (a separate, least-privilege user per the
# Percona PMM docs — MySQL/PXC, PostgreSQL, MongoDB, Valkey). Created only on
# nodes that are associated with a PMM server.
PMM_PASSWORD=pmm_password
