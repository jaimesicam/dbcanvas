# Host interface the application is reachable on. Default: 127.0.0.1 (private —
# this machine only).
# - 127.0.0.1 (or another IPv4, e.g. 192.168.1.10) restricts access to that
#   interface. In Docker this binds the published port to that host interface;
#   the container itself always listens on all interfaces internally.
# - 0.0.0.0 exposes the app on all interfaces (e.g. your LAN).
APP_HOST=127.0.0.1

# Port the application listens on (host + container). Default: 8080
APP_PORT=8080

# The platform this installation targets. Exactly one of linux/amd64 or
# linux/arm64 (default: linux/amd64). It drives the app image build AND the
# systemd base images: `make images` builds only this platform, and
# `make versions` only probes/records images on it — so the host never spends
# time emulating the other architecture.
DOCKER_PLATFORM=linux/amd64

# Host interface that deployed stack nodes publish their exposed ports on (every
# node that exports a DB/router/admin port to the host — PXC, ProxySQL, Percona
# Server, PostgreSQL, MongoDB mongos/members, Valkey, HAProxy, SeaweedFS, PMM,
# etc.). Default: 127.0.0.1 (private — reachable only from this machine).
# - 127.0.0.1 binds published ports to loopback only.
# - 0.0.0.0 publishes them on all host interfaces (e.g. your LAN) — the old
#   Docker default. Set another IPv4 (e.g. 192.168.1.10) to pin one interface.
# The container itself always listens on all interfaces internally; this only
# controls the host-side binding of the published port.
CONTAINER_BIND_IP=127.0.0.1

# How long (in minutes) a provisioner waits for a dependency — an associated
# cluster, node, or shared service — to become ready before failing the deploy
# (e.g. "associated PXC cluster ... did not become ready within ..."). Raise
# this when deploying large stacks with many containers, which routinely take
# longer than a few minutes to come up. Default: 60
DEPLOYMENT_TIMEOUT=60

# Domain used to configure deployed stacks (e.g. the Intranet node: LDAP base DN,
# mail, DNS, CA). Default: example.net
DOMAIN=example.net

# Database users created on deployed Percona XtraDB Cluster nodes: an
# application user, a replication user, a monitoring user (used by ProxySQL's
# health checks as MONITOR_USERNAME), and a cluster admin user (used by
# ProxySQL's proxysql-admin as CLUSTER_USERNAME). Their passwords are taken
# from here.
APP_PASSWORD=app_password
REPL_PASSWORD=repl_password
MONITOR_PASSWORD=monitor_password
CLUSTER_PASSWORD=cluster_password

# Password for the clustercheck@'localhost' user (PROCESS privilege) created on every
# MySQL-family node (MySQL replication, standalone Percona Server, and PXC). It backs the
# PXC "clustercheck" health endpoint on :9200 that an HAProxy load balancer polls to route
# only to wsrep-Synced nodes. Created in each node's baseline like the users above, so it
# exists cluster-wide without a post-baseline write (which could become an errant
# cross-cluster replication transaction). Default: cluster_password
CLUSTERCHECK_PASSWORD=cluster_password

# Credentials for deployed database and ProxySQL nodes are taken exclusively from
# this file — they can no longer be set per-node on the canvas, and a redeploy
# re-reads these values. Variables named after a specific engine (MYSQL_*,
# POSTGRES_*, VALKEY_*, MONGODB_*, PROXYSQL_*) apply only to that engine family;
# the rest (APP/REPL/MONITOR/CLUSTER/PMM) are shared where relevant.

# Root (superuser) password for every MySQL-family database node — Percona
# XtraDB Cluster, MySQL replication, InnoDB / Group Replication, and standalone
# Percona Server (root@localhost).
MYSQL_ROOT_PASSWORD=root_password

# Password for the dedicated remote superuser account admin@'%' created on every
# MySQL-family node (PXC, MySQL replication, InnoDB / Group Replication, standalone
# Percona Server). root@localhost cannot connect over the network, so this account
# is the network-reachable full-privilege admin.
MYSQL_ADMIN_PASSWORD=admin_password

# Superuser (postgres) password for every PostgreSQL node.
POSTGRES_PASSWORD=postgres_password

# Default-user password (requirepass / masterauth) for every Valkey node —
# standalone and Valkey Cluster.
VALKEY_PASSWORD=valkey_password

# Admin-interface (port 6032) password for the ProxySQL 'admin' user on every
# ProxySQL node — standalone and ProxySQL cluster members.
PROXYSQL_ADMIN_PASSWORD=admin_password

# Admin-user password for every MongoDB (Percona Server for MongoDB) node —
# standalone, replica set, and sharded cluster.
MONGODB_ADMIN_PASSWORD=admin_password

# Password for the PMM server's Grafana "admin" user (the PMM web UI login).
# Distinct from PMM_PASSWORD below, which is the least-privilege monitoring
# account PMM uses to scrape the databases. A per-node password set on the
# canvas overrides this.
PMM_ADMIN_PASSWORD=admin_password

# Password for the Keycloak node's "admin" console user.
KEYCLOAK_PASSWORD=keycloak_password

# Password set on the sample Keycloak users that the SSO integrations create in
# Keycloak — PostgreSQL (jane, john), MongoDB standalone (alice, bob) and PMM
# (alice, bob). It was previously a random per-deploy secret that was never shown
# anywhere, which made those accounts unusable; it is now taken from here and
# re-read on every redeploy. These are demo/test identities — do not reuse this
# password for anything real. Default: keycloak_user_password
KEYCLOAK_USER_PASSWORD=keycloak_user_password

# Password for the Ubuntu VNC desktop node — it is both the desktop login for
# VNC_USER and the VNC access code. VncAuth only uses the first 8 characters, so
# this default authenticates as "vnc_pass". A per-node password set on the canvas
# overrides this.
VNC_PASSWORD=vnc_password

# Password for the dedicated "pmm" monitoring account that PMM uses to scrape
# metrics from each monitored database (a separate, least-privilege user per the
# Percona PMM docs — MySQL/PXC, PostgreSQL, MongoDB, Valkey). Created only on
# nodes that are associated with a PMM server.
PMM_PASSWORD=pmm_password

# Administrator password for the Samba AD DC node — this is the AD domain
# Administrator account, used to provision the domain and to bind for LDAP /
# Kerberos management. Must satisfy Active Directory complexity (at least three
# of: uppercase, lowercase, digit, symbol). If provisioning rejects it, set a
# compliant one here and redeploy. Default: SambaPassword2026
SAMBA_PASSWORD=SambaPassword2026
